<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.test_student_management.controller.LoginController"
           styleClass="root-pane">
    <VBox alignment="CENTER" spacing="0" maxWidth="380" maxHeight="340"
          styleClass="card">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label text="Student Management" styleClass="app-title"/>
        <Label text="Sign in to continue" styleClass="app-subtitle"/>

        <VBox spacing="6" style="-fx-padding: 24 0 0 0;">
            <Label text="Username" styleClass="field-label"/>
            <TextField fx:id="usernameField" promptText="Enter username" styleClass="text-input"/>

            <Label text="Password" styleClass="field-label" style="-fx-padding: 10 0 0 0;"/>
            <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="text-input"/>

            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

            <Button text="Login" onAction="#handleLogin"
                    styleClass="btn-primary" maxWidth="Infinity"
                    style="-fx-padding: 10 0 10 0; -fx-font-size: 14px; -fx-cursor: hand;"/>
        </VBox>
    </VBox>
</StackPane>