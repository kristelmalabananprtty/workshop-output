<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.test_student_management.controller.AddStudentController"
      spacing="0" styleClass="root-pane">

    <!-- HEADER -->
    <HBox styleClass="form-header" alignment="CENTER_LEFT">
        <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>
        <Label fx:id="formTitleLabel" text="Add New Student" styleClass="form-title"/>
    </HBox>

    <!-- BODY -->
    <VBox spacing="12" VBox.vgrow="ALWAYS">
        <padding><Insets top="20" right="28" bottom="20" left="28"/></padding>

        <GridPane hgap="16" vgap="10">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Student Number *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="studentNumberField" promptText="e.g. 2026-0001"
                       styleClass="text-input"
                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>

            <Label text="Course *" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <ComboBox fx:id="courseCombo" promptText="Select course" maxWidth="Infinity"
                      GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="First Name *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="firstNameField" promptText="First name"
                       styleClass="text-input"
                       GridPane.columnIndex="0" GridPane.rowIndex="3"/>

            <Label text="Last Name *" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            <TextField fx:id="lastNameField" promptText="Last name"
                       styleClass="text-input"
                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Label text="Year Level *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <ComboBox fx:id="yearCombo" maxWidth="Infinity"
                      GridPane.columnIndex="0" GridPane.rowIndex="5"/>

            <Label text="Email" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            <TextField fx:id="emailField" promptText="email@example.com"
                       styleClass="text-input"
                       GridPane.columnIndex="1" GridPane.rowIndex="5"/>

            <Label text="Phone" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
            <TextField fx:id="phoneField" promptText="09XXXXXXXXX"
                       styleClass="text-input"
                       GridPane.columnIndex="0" GridPane.rowIndex="7"/>
        </GridPane>

        <Label fx:id="statusLabel" wrapText="true" styleClass="status-label"/>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- BUTTONS -->
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Cancel" onAction="#handleCancel" styleClass="btn-outline"/>
            <Button text="Save Student" onAction="#handleSave" styleClass="btn-primary"/>
        </HBox>
    </VBox>
</VBox>
